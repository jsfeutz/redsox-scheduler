# Host port 5433 matches docker-compose.yml (db maps 5433:5432). Use 5433 for local npm run dev.
DATABASE_URL="postgresql://ringers:ringers2026@localhost:5433/ringers"
NEXTAUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Resend SMTP (optional local test). From domain must be verified in Resend.
# SMTP_HOST="smtp.resend.com"
# SMTP_PORT="587"
# SMTP_USER="resend"
# SMTP_PASS="re_..."
# SMTP_FROM="Rubicon Redsox Notification <noreply@rubiconredsox.com>"

# Resend inbound (support@rubiconredsox.com): add MX + receiving domain in Resend dashboard, then:
# RESEND_WEBHOOK_SECRET="whsec_..."   # from Resend → Webhooks (Signing secret)
# Webhook URL: https://schedule.rubiconredsox.com/api/webhooks/resend  event: email.received
# Inbound forward: RESEND_API_KEY must be full-access (read received mail). SMTP_PASS may be send-only.
# RESEND_API_KEY="re_..."             # full access — required to fetch inbound body from /emails/receiving
# Production: forward support inbox → personal mail (Resend Receiving + webhook required)
# RESEND_INBOUND_FORWARD_TO="jon@feutz.com"
# RESEND_INBOUND_SUPPORT_ADDRESS="support@rubiconredsox.com"   # default if unset

# Optional: persist org branding icons to S3 (recommended for Lightsail containers).
# If unset, files go to uploads/branding on disk (fine for local dev).
# BRANDING_S3_BUCKET="your-bucket-name"
# BRANDING_S3_PREFIX="branding"
# AWS_REGION="us-east-2"
# Uses AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY if set; else *_SNS vars.

# Organization timezone (IANA). All server-generated event times (emails, SMS,
# cron reminders) are formatted in this zone. Default: America/Chicago.
# ORG_TIMEZONE="America/Chicago"
# NEXT_PUBLIC_ORG_TIMEZONE="America/Chicago"

# SMS (AWS SNS, same region as toll-free registration — us-east-2).
# Set to your approved toll-free E.164 so messages use the registered number (AWS.MM.SMS.OriginationNumber).
# AWS_PROFILE=feutz-aws aws pinpoint-sms-voice-v2 describe-phone-numbers --region us-east-2
# SMS_ORIGINATION_NUMBER="+18445010080"
